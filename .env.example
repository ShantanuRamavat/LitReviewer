# =============================================================================
# LitReviewer — Environment Variables
# Copy this file to .env and fill in the values.
# This file is used by Docker Compose.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# LLM — Groq (primary)
# Free tier: https://console.groq.com
# Default model: llama-3.3-70b-versatile
# -----------------------------------------------------------------------------
LLM_PROVIDER=groq
GROQ_API_KEY=your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# -----------------------------------------------------------------------------
# Web Search — Tavily
# Get your key at: https://tavily.com
# -----------------------------------------------------------------------------
TAVILY_API_KEY=your-tavily-key-here
TAVILY_MAX_RESULTS=8

# -----------------------------------------------------------------------------
# PostgreSQL
# Docker Compose service name is "postgres", so the host is "postgres".
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=research
POSTGRES_USER=research_user
POSTGRES_PASSWORD=research_pass
POSTGRES_URL=postgresql+asyncpg://research_user:research_pass@postgres:5432/research

# -----------------------------------------------------------------------------
# Qdrant vector database
# Docker Compose service name is "qdrant".
# -----------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333

# -----------------------------------------------------------------------------
# Redis
# Docker Compose service name is "redis".
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# CORS — allowed origins for the FastAPI backend
# -----------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:3000"]

# -----------------------------------------------------------------------------
# Research tuning
# -----------------------------------------------------------------------------
MAX_ITERATIONS=3
MIN_QUALITY_SCORE=0.7
RAG_TOP_K=8

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=10
