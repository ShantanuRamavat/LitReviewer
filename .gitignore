# =============================================================================
# LitReviewer — .gitignore
# =============================================================================

# Environment files — NEVER commit real API keys
.env
backend/.env

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
.uv/
*.egg-info/
dist/
build/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# HuggingFace model cache (large, auto-downloaded on first run)
.cache/
backend/.cache/

# Node / Next.js
node_modules/
frontend/.next/
frontend/out/
frontend/build/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
