# =============================================================================
# LitReviewer — Backend Local Development Environment
# Copy this file to backend/.env for running the backend outside Docker.
# Database hosts use "localhost" instead of Docker service names.
# =============================================================================

ENVIRONMENT=development
LOG_LEVEL=INFO

LLM_PROVIDER=groq
GROQ_API_KEY=your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

TAVILY_API_KEY=your-tavily-key-here
TAVILY_MAX_RESULTS=20

# Localhost URLs for running outside Docker Compose
POSTGRES_URL=postgresql+asyncpg://research_user:research_pass@localhost:5433/research
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379

CORS_ORIGINS=["http://localhost:3000"]

MAX_ITERATIONS=3
MIN_QUALITY_SCORE=0.7
RAG_TOP_K=8
RATE_LIMIT_PER_MINUTE=10
